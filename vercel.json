{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm install --no-save @rollup/rollup-linux-x64-gnu@$(node -p \"require('rollup/package.json').version\") && npm run build -w client",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "docs/learnings/**"
    }
  }
}
