# Supabase (https://supabase.com 프로젝트 설정에서 복사)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# 서버 포트 (선택, 기본 3001)
# PORT=3001

# 링크/스크랩 AI 제안 — 제공자: ollama(기본) | google | gemini
# AI_TEXT_PROVIDER=google
# Google AI Studio(https://aistudio.google.com/apikey)에서 발급한 키
# GEMINI_API_KEY=
# 선택 모델 (기본 gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Ollama 사용 시 (기본값)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=lfm2:24b
