# Supabase (https://supabase.com 프로젝트 설정에서 복사)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# 서버 포트 (선택, 기본 3001)
# PORT=3001

# 링크/스크랩 AI — 클라이언트 헤더 X-AI-Provider로 로컬(Ollama) / API(Gemini) 선택 (기본 로컬)
# Google AI Studio(https://aistudio.google.com/apikey)에서 발급한 키 (API 모드 시 필요)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Ollama (로컬 모드, 기본 모델 태그 gemma4)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=gemma4
